# ─── Daily backend environment ──────────────────────────────────────────────
# Copy to `.env` and fill in. NEVER commit `.env`. Only ANTHROPIC_API_KEY and the
# JWT/webhook secrets are real secrets; everything else is configuration.

# Runtime ---------------------------------------------------------------------
NODE_ENV=development          # development | test | production
PORT=8080
LOG_LEVEL=info                # trace|debug|info|warn|error|fatal
ALLOWED_ORIGIN=*              # CORS allow-list (comma-separated) or *

# Database --------------------------------------------------------------------
# When DATABASE_URL is empty the backend boots an in-memory Postgres (pg-mem),
# auto-migrates, and seeds starter templates — zero external services required.
# Set a real URL in production.
DATABASE_URL=
# DATABASE_URL=postgres://user:pass@localhost:5432/daily
DB_SSL=false
DB_POOL_MAX=10

# Auth / JWT ------------------------------------------------------------------
# REQUIRED in production. In dev a deterministic default is used if unset.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=900            # seconds (15 min)
JWT_REFRESH_TTL=2592000       # seconds (30 days)
JWT_ISSUER=daily-backend
JWT_AUDIENCE=daily-app

# Apple / Google sign-in (verification is MOCKED until configured) ------------
APPLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# Anthropic / Claude ----------------------------------------------------------
# When ANTHROPIC_API_KEY is empty, generation uses a deterministic MOCK
# generator (no network, no spend) so the whole pipeline is testable offline.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5          # workhorse (free tier)
ANTHROPIC_MODEL_PREMIUM=claude-sonnet-4-6 # Daily Plus quality toggle
ANTHROPIC_MAX_TOKENS=400
GENERATION_INTENT_MAX_CHARS=500

# Expo push (MOCKED until configured) -----------------------------------------
EXPO_ACCESS_TOKEN=

# RevenueCat webhook (signature check MOCKED until configured) -----------------
REVENUECAT_WEBHOOK_SECRET=

# Rate limiting ---------------------------------------------------------------
RATE_LIMIT_PER_MIN=120        # default per-IP/user budget
GENERATE_RATE_LIMIT_PER_MIN=20

# Background workers ----------------------------------------------------------
WORKERS_ENABLED=true
GENERATION_LEAD_DAYS=2        # pre-generate today + N-1 future days
GENERATION_TICK_MS=15000
NOTIFICATION_TICK_MS=15000
ROLLUP_TICK_MS=3600000        # hourly rollup pass (nightly in prod via cron)

# Free tier -------------------------------------------------------------------
FREE_PROMPT_LIMIT=2
FREE_DAILY_REGEN_CREDITS=1
