# ---------------------------------------------------------------------------
# Daily — mobile app environment (EXPO_PUBLIC_* values are embedded in the
# client bundle and are NOT secret). The real secret (ANTHROPIC_API_KEY) lives
# ONLY on the backend — never here. See PLANNING.md §3.7.
# ---------------------------------------------------------------------------

# Base URL of the Daily backend (the /v1 cloud API in backend/). Point this at
# your local backend (`cd backend && npm run dev` -> http://localhost:8080) or a
# deployed instance. The app talks to `${EXPO_PUBLIC_BACKEND_URL}/v1/...`.
#
# On a device/simulator, localhost is the device, not your machine:
#   iOS simulator:      http://localhost:8080
#   Android emulator:   http://10.0.2.2:8080
#   Physical device:    http://<your-LAN-IP>:8080
EXPO_PUBLIC_BACKEND_URL=

# Auth is handled at runtime: the app bootstraps an anonymous JWT session via
# POST /v1/auth/anonymous and stores the access/refresh tokens on-device. The
# /v1 API does NOT use a shared client token, so this is unused by /v1 and kept
# only for backwards-compat with the old stateless proxy.
EXPO_PUBLIC_BACKEND_CLIENT_TOKEN=

# When "true" (or when EXPO_PUBLIC_BACKEND_URL is blank) the app runs entirely on
# local mock data and never touches the network (Phase-1 default). Set to
# "false" AND set EXPO_PUBLIC_BACKEND_URL to wire the app to the backend.
EXPO_PUBLIC_USE_MOCKS=true
